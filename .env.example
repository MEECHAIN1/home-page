# ===== MeeChain Environment Configuration =====

# ── OpenAI Configuration ──────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# ── RPC Configuration ─────────────────────────────────────────────
# Primary RPC URL (Replit workspace Hardhat node)
DRPC_RPC_URL=https://42c7069b-865d-4df8-b7c6-7e205ac23047-00-3hc01fewihowr.pike.replit.dev:3003

# dRPC Access Key (optional, for frontend DApp)
DRPC_ACCESS_KEY=your_drpc_access_key_here

# Fallback RPC URL (same as primary for development)
VITE_RPC_URL=https://42c7069b-865d-4df8-b7c6-7e205ac23047-00-3hc01fewihowr.pike.replit.dev:3003

# Chain ID (13390 = 0x344e)
CHAIN_ID=13390

# ── NodeCore & NodeCloud (Optional) ───────────────────────────────
# NodeCore API Key (server-side proxy layer)
NODECORE_API_KEY=your_nodecore_api_key_here

# NodeCloud API Key (infrastructure management)
NODECLOUD_API_KEY=your_nodecloud_api_key_here

# NodeCloud Stats Key (monitoring & cost intelligence)
NODECLOUD_STATS_KEY=your_nodecloud_stats_key_here

# ── Smart Contract Addresses ──────────────────────────────────────
# MEE Token Contract
VITE_TOKEN_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# MeeBot NFT Contract
VITE_NFT_CONTRACT_ADDRESS=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512

# Staking Contract
VITE_STAKING_CONTRACT_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0

# ── Server Configuration ──────────────────────────────────────────
# Server port
PORT=3000

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://meechain.run.place

# ── Notes ─────────────────────────────────────────────────────────
# 1. Copy this file to .env and fill in your actual values
# 2. Never commit .env to version control
# 3. RPC URL must use HTTPS for production
# 4. Chain ID 13390 is for MeeChain (Ritual Chain)
# 5. Contract addresses are auto-generated after deployment
