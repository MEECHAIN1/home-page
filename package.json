{
  "name": "webapp",
  "version": "1.0.0",
  "description": "แดชบอร์ด Web Application สำหรับ MeeChain Blockchain Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "hardhat": "npx hardhat node",
    "deploy": "cd blockchain && npx hardhat run scripts/deploy.js --network localhost",
    "test:rpc": "bash scripts/test-rpc.sh",
    "infra:start": "bash scripts/start.sh",
    "infra:stop": "bash scripts/stop.sh",
    "docs": "jsdoc -c jsdoc.json",
    "docs:watch": "nodemon --watch src --watch server.js --exec \"npm run docs\""
  },
  "keywords": [
    "MeeChain",
    "Blockchain",
    "Dashboard"
  ],
  "author": "Thanawat",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "express": "^4.18.2",
    "js-yaml": "^4.1.1",
    "openai": "^6.25.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "docdash": "^2.0.2",
    "hardhat": "^2.28.0",
    "install": "^0.13.0",
    "jsdoc": "^4.0.5",
    "npm": "^11.11.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
